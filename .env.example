# ─────────────────────────────────────────────────────────────
# Prism — environment configuration
# Copy this file to ".env" and add your key:
#   copy .env.example .env     (Windows)
#   cp .env.example .env       (macOS / Linux)
# ─────────────────────────────────────────────────────────────

# ── FREE setup (default) ─────────────────────────────────────
# One free key, no credit card. Powers all three columns with free
# OpenRouter models. Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Optional ─────────────────────────────────────────────────
GATEWAY_PORT=8787
EVAL_SERVICE_URL=http://localhost:8000
MAX_OUTPUT_TOKENS=1024

# ── PRO setup (later) ────────────────────────────────────────
# To use native GPT / Claude / Gemini instead of free models, add the
# keys below and switch the matching slot in gateway/src/config.ts
# (set its `kind`, `id`, `apiKeyEnv`, and remove `baseUrl`).
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
