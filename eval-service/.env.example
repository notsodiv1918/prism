# The evaluation service runs in two modes:
#
#  1. Heuristic-only (default) — no keys needed. Deterministic, fast, offline.
#  2. LLM-as-judge — if a key below is present, an LLM scores each response and
#     its rating is blended with the heuristics. Set JUDGE_PROVIDER to pick which.

JUDGE_PROVIDER=          # openrouter | openai | anthropic | (blank = heuristic only)

# FREE judge via OpenRouter (recommended — same key as the app, no card)
OPENROUTER_API_KEY=
OPENROUTER_JUDGE_MODEL=openai/gpt-oss-120b:free

# Paid judges (for the "pro" setup later)
OPENAI_API_KEY=
OPENAI_JUDGE_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=
ANTHROPIC_JUDGE_MODEL=claude-haiku-4-5-20251001
